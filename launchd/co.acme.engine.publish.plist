<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Acme engine STEP C — PUBLISH. Fires at all 5 PT slots; publish_slot.py infers which
     slot from the clock and publishes that slot's APPROVED jobs. SUPERVISED by default
     (publish.py dry-run) until the GO_LIVE flag file exists; --go is NOT set here so the
     flag is the only go-live switch. STOP flag + compliance hold both halt it. -->
<plist version="1.0">
<dict>
  <key>Label</key><string>co.acme.engine.publish</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Library/Frameworks/Python.framework/Versions/3.13/bin/python3</string>
    <string>/Users/operator/.openclaw/workspace/acme/publish_slot.py</string>
  </array>
  <key>WorkingDirectory</key><string>/Users/operator/.openclaw/workspace/acme</string>
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Hour</key><integer>8</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>11</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>13</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>16</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>19</integer><key>Minute</key><integer>0</integer></dict>
  </array>
  <key>StandardOutPath</key><string>/Users/operator/.openclaw/workspace/acme/logs/engine.publish.log</string>
  <key>StandardErrorPath</key><string>/Users/operator/.openclaw/workspace/acme/logs/engine.publish.log</string>
  <key>RunAtLoad</key><false/>
  <key>EnvironmentVariables</key>
  <dict><key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string></dict>
</dict>
</plist>
