# Acme content engine — environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored and MUST NEVER be committed.
# Each collaborator keeps their own local .env; secrets are never shared through git.

# --- LLM / generation ---
OPENROUTER_API_KEY=

# --- Research / sourcing ---
SEARCHAPI_API_KEY=
FIRECRAWL_API_KEY=
APIFY_API_KEY=

# --- Publishing ---
BLOTATO_API_KEY=

# --- Google Sheets (Content Matrix); also needs acme-google-credentials.json (gitignored) ---
GOOGLE_SHEET_ID=

# --- Telegram review bot ---
TELEGRAM_BOT_TOKEN=
ENGINE_TELEGRAM_BOT_TOKEN=
ENGINE_TELEGRAM_CHAT_ID=

# NOTE: Higgsfield (video/image generation) is accessed via the OpenClaw MCP connector,
# not an .env key. Media outputs (output/, asset_cache/, *.mp4) are gitignored & regenerated
# locally — they are never pushed to GitHub.
